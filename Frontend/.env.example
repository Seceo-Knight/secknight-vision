# Backend API base URL (v3 REST endpoint)
VITE_API_URL=http://localhost:3000/api/v3

# WebSocket URL for live monitoring / notifications
VITE_SOCKET_URL=wss://localhost:3000

# Backend v4 URL — used for employee login and newer endpoints
VITE_BACKEND_V4_URL=http://localhost:3000

VITE_CRYPTO_PASSWORD=your_secure_password
VITE_PASSWORD_IV=your_secure_iv

# Show the EMP AI Assistant (header button, dashboard "Ask EMP AI ASSISTANT"
# card, and the AI icons on report cards) only when set to "true".
VITE_SHOW_EMP_AI_ASSISTANT=false